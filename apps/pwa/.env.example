VITE_AAD_CLIENT_ID=
VITE_AAD_TENANT_ID=

# --- Open the PWA on your iPhone (Safari) via a public URL ---
# 1) From apps/pwa run: npm run dev
# 2) Expose localhost:5173 with a tunnel, for example:
#    - Cloudflare: npx cloudflared tunnel --url http://localhost:5173
#    - ngrok: ngrok http 5173
# 3) Open the printed https://... URL in Safari on your phone.
# 4) In Entra ID > App registration > Authentication > SPA redirect URIs, add that exact
#    origin (e.g. https://abc-123.trycloudflare.com) — MSAL uses window.location.origin.
#
# PWA: `vite-plugin-pwa` injects manifest + service worker. In Safari use Share > Add to Home Screen
# after the site loads over HTTPS. `npm run dev` also registers the SW (devOptions.enabled).

# Microsoft Graph site/list IDs.
# Example siteId format: slcounty.sharepoint.com,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy
VITE_GRAPH_SITE_ID=
VITE_GRAPH_REQUESTS_LIST_ID=
VITE_GRAPH_SELFHELP_LIST_ID=
VITE_GRAPH_AUDIT_LIST_ID=

